# Database
# Local dev: postgresql://app_user:app_password@localhost:5432/oneonone_dev
# Neon: get connection string from neon.tech dashboard (use "pooled" URL for app)
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/oneonone_dev

# Seed (superuser connection for seeding -- bypasses RLS, local dev only)
SEED_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oneonone_dev

# Admin (superuser for auth flows -- registration, login, password reset bypass RLS)
# Neon: use the non-pooled (direct) connection string here
DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/oneonone_dev

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_MASTER_KEY=

# Auth.js
AUTH_SECRET=              # Generate with: openssl rand -base64 33
# AUTH_TRUST_HOST=true   # Only needed for non-Vercel deployments (e.g. Docker, Coolify)

# OAuth (optional -- leave empty to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls              # "tls" for STARTTLS on 587, "ssl" for implicit TLS on 465
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=1on1 <noreply@1on1.works>

# Feedback
# FEEDBACK_EMAIL_TO=support@1on1.works        # Override the support inbox that receives new feedback reports
# FEEDBACK_NOTIFICATION_LOCALE=en             # Locale ("en" | "ro") used for platform-addressed feedback emails

# AI (Anthropic via Vercel AI SDK)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:4300
AUTH_URL=http://localhost:4300   # Set to your public URL in production (e.g. https://yourdomain.com)

# Sentry — Error Monitoring, Tracing, Session Replay, AI Monitoring
# Get DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
# "development" | "staging" | "production"
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Optional: override sample rate (0.0–1.0). Defaults: 1.0 in dev, 0.1 in prod
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Source map upload (build-time only) — set in CI secrets or .env.sentry-build-plugin
SENTRY_AUTH_TOKEN=
SENTRY_ORG=surcod
SENTRY_PROJECT=1on1
